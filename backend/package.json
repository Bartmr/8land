{
  "name": "@app/api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "engines": {
    "node": "16"
  },
  "scripts": {
    "seed": "npm run ts-node ./development/seed.ts",
    "tear-down-databases": "npm run ts-node ./development/tear-down-databases.ts",
    "start:dev": "NODE_ENV=development nest start --path tsconfig.build.json --watch",
    "start:dev:debug": "NODE_ENV=development nest start --path tsconfig.build.json --watch --debug",
    "start:prod": "typeorm migration:run && node dist/src/main.js",
    "clean": "rimraf dist node_modules/.cache/webpack",
    "build": "npm run clean:api && nest build --path tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint --ext .ts,.tsx --max-warnings 0 .",
    "lint:fix": "eslint --ext .ts,.tsx --max-warnings 0 --fix .",
    "reset-repository": "git clean -Xdf",
    "nest": "nest",
    "typeorm": "npm run ts-node ./node_modules/.bin/typeorm",
    "ts-node": "ts-node --project tsconfig.build.json --transpile-only -r tsconfig-paths/register"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.121.0",
    "@nestjs/common": "^8.4.1",
    "@nestjs/core": "^8.4.1",
    "@nestjs/platform-express": "^8.4.1",
    "@nestjs/swagger": "^5.2.0",
    "@nestjs/typeorm": "^8.1.4",
    "@openzeppelin/contracts": "^4.7.0",
    "axios": "^0.27.2",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.0.1",
    "ethers": "^5.6.9",
    "firebase-admin": "^11.0.0",
    "glob": "^8.0.3",
    "not-me": "^5.3.0",
    "pg": "^8.7.3",
    "read-chunk": "^4.0.2",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.5.5",
    "sharp": "^0.30.7",
    "source-map-support": "^0.5.21",
    "swagger-ui-express": "^4.4.0",
    "typeorm": "~0.3.0",
    "uuid": "^8.3.2",
    "validator": "^13.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.18.6",
    "@nestjs/cli": "^8.2.3",
    "@nestjs/schematics": "^8.0.8",
    "@nestjs/testing": "^8.4.1",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.17.13",
    "@types/multer": "^1.4.7",
    "@types/node": "^16.11.21",
    "@types/pg": "^8.6.5",
    "@types/sharp": "^0.30.4",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^8.3.4",
    "@types/validator": "^13.7.4",
    "@types/webpack-env": "^1.17.0",
    "@typescript-eslint/eslint-plugin": "^5.30.5",
    "@typescript-eslint/parser": "^5.30.5",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-typescript": "^3.2.4",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-node": "^11.1.0",
    "npm-check-updates": "^15.2.1",
    "prettier": "^2.7.1",
    "run-script-webpack-plugin": "^0.1.1",
    "source-map-loader": "^4.0.0",
    "supertest": "^6.2.4",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.8.2",
    "tsconfig-paths": "^4.0.0",
    "typechain": "^8.1.0",
    "typescript": "^4.7.4",
    "webpack-node-externals": "^3.0.0"
  }
}
